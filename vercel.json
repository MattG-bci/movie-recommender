{
  "builds": [
    {
      "src": "src/api/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/api/app.py"
    }
  ],
  "installCommand": "pip install poetry && poetry install",
  "build": {
    "env": {
      "PYTHON_VERSION": "3.12"
    }
  }
}
